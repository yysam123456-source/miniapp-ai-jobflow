{
  "miniprogramRoot": "./",
  "cloudfunctionRoot": "cloudfunctions/",
  "projectname": "miniapp-ai-jobflow",
  "appid": "wxAPPID_PLACEHOLDER",
  "description": "AI 求职一站式 · 证件照编辑 + 简历制作 + AI 润色（全免费 CloudBase + 混元）",
  "setting": {
    "urlCheck": false,
    "es6": true,
    "enhance": true,
    "postcss": true,
    "minified": true,
    "newFeature": true,
    "bigPackageSizeSupport": true,
    "ignoreDevUnusedFiles": true
  },
  "compileType": "miniprogram",
  "libVersion": "latest",
  "packOptions": {
    "ignore": [
      { "type": "folder", "value": "deliverables" },
      { "type": "folder", "value": "refs" },
      { "type": "folder", "value": "cloudfunctions" },
      { "type": "folder", "value": ".workbuddy" },
      { "type": "file", "value": "README.md" },
      { "type": "file", "value": "config.example.js" },
      { "type": "file", "value": "deploy.sh" }
    ]
  },
  "condition": {}
}
