/* package-resume/pages/resume/polish.wxss */
@import "../../../styles/tokens.wxss";
@import "../../../styles/components.wxss";

.head { padding: var(--sp-6) 0 var(--sp-3); }
.head__title { display: block; font-size: var(--fs-display); font-weight: var(--fw-bold); color: var(--c-ink); }
.head__sub { display: block; margin-top: var(--sp-2); font-size: var(--fs-caption); color: var(--c-ink-2); }

.opt-card { padding: var(--sp-4); margin-bottom: var(--sp-4); }
.opt-card__label { display: block; font-size: var(--fs-caption); font-weight: var(--fw-semi); color: var(--c-ink-2); margin-bottom: var(--sp-2); }
.opt-card__label:not(:first-child) { margin-top: var(--sp-4); }
.seg--block { display: flex; margin-bottom: var(--sp-2); }
.seg--block .seg-btn { flex: 1; text-align: center; }
.textarea { width: 100%; height: 180rpx; line-height: var(--lh-base); padding: var(--sp-3); box-sizing: border-box; }

.result-head { display: flex; align-items: baseline; justify-content: space-between; margin: var(--sp-4) 0 var(--sp-2); }
.result-head__title { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--c-ink); }
.result-head__hint { font-size: var(--fs-mini); color: var(--c-ink-3); }

.diff-card { padding: 0; margin-bottom: var(--sp-3); overflow: hidden; }
.diff-card__bar { display: flex; justify-content: space-between; align-items: center; padding: var(--sp-3) var(--sp-4); background: var(--c-card); }
.diff-card__reason { font-size: var(--fs-body); font-weight: var(--fw-semi); color: var(--c-ink); flex: 1; }
.diff-card__arrow { font-size: var(--fs-caption); color: var(--c-brand-700); margin-left: var(--sp-2); }
.diff-card__body { padding: 0 var(--sp-4) var(--sp-4); background: var(--c-surface); }
.diff-line { display: flex; gap: var(--sp-2); padding: var(--sp-2) 0; align-items: flex-start; }
.diff-tag { flex: 0 0 72rpx; font-size: var(--fs-mini); font-weight: var(--fw-bold); color: var(--c-ink-3); padding-top: 4rpx; }
.diff-tag--ok { color: var(--c-brand-700); }
.diff-text { flex: 1; font-size: var(--fs-caption); color: var(--c-ink); line-height: var(--lh-base); }
.diff-line--before .diff-text { color: var(--c-ink-2); text-decoration: line-through; text-decoration-color: rgba(229,72,77,0.5); }
.diff-line--after .diff-text { color: var(--c-ink); }

.export-btn { margin-top: var(--sp-4); margin-bottom: var(--sp-12); }
