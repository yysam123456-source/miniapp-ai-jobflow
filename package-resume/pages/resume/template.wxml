<!-- package-resume/pages/resume/template.wxml -->
<view class="page-container">
  <view class="head">
    <text class="head__title">选择模板</text>
    <text class="head__sub">AI 已解析好内容，挑个版式就好</text>
  </view>

  <view class="tpl-list">
    <view
      wx:for="{{templates}}"
      wx:key="id"
      class="tpl-card {{selected===item.id?'tpl-card--on':''}}"
      data-id="{{item.id}}"
      bindtap="selectTemplate"
    >
      <view class="tpl-card__preview" style="background:{{item.swatch}}">
        <view class="tpl-card__lines">
          <view class="ln ln--t"></view>
          <view class="ln"></view>
          <view class="ln"></view>
          <view class="ln ln--s"></view>
        </view>
      </view>
      <view class="tpl-card__meta">
        <view class="tpl-card__row">
          <text class="tpl-card__name">{{item.name}}</text>
          <text class="chip {{selected===item.id?'on':''}}">{{item.tag}}</text>
        </view>
        <text class="tpl-card__desc">{{item.desc}}</text>
      </view>
      <view wx:if="{{selected===item.id}}" class="tpl-card__check">✓</view>
    </view>
  </view>

  <view class="footer safe-bottom">
    <button class="btn btn-primary btn-block" loading="{{loading}}" disabled="{{loading}}" bindtap="apply">
      {{loading ? '套用中…' : '套用并编辑'}}
    </button>
  </view>
</view>
