/* package-resume/pages/resume/template.wxss */
@import "../../../styles/tokens.wxss";
@import "../../../styles/components.wxss";

.head { padding: var(--sp-6) 0 var(--sp-4); }
.head__title { display: block; font-size: var(--fs-display); font-weight: var(--fw-bold); color: var(--c-ink); }
.head__sub { display: block; margin-top: var(--sp-2); font-size: var(--fs-caption); color: var(--c-ink-2); }

.tpl-list { display: flex; flex-direction: column; gap: var(--sp-3); padding-bottom: var(--sp-12); }

.tpl-card {
  position: relative; display: flex; gap: var(--sp-4);
  background: var(--c-card); border: 2rpx solid var(--c-border);
  border-radius: var(--r-lg); padding: var(--sp-4); box-shadow: var(--sh-1);
  transition: transform var(--dur-press) var(--ease-out), border-color var(--dur-press) var(--ease-out);
}
.tpl-card--on { border-color: var(--c-brand); box-shadow: var(--sh-2); }
.tpl-card--on:active { transform: translateY(-4rpx); }

.tpl-card__preview {
  flex: 0 0 150rpx; height: 200rpx; border-radius: var(--r-md);
  padding: var(--sp-3); display: flex; align-items: center; justify-content: center;
}
.tpl-card__lines { width: 100%; display: flex; flex-direction: column; gap: 10rpx; }
.ln { height: 8rpx; border-radius: var(--r-pill); background: rgba(255,255,255,0.55); }
.ln--t { height: 16rpx; width: 60%; background: rgba(255,255,255,0.9); }
.ln--s { width: 70%; }

.tpl-card__meta { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: var(--sp-2); }
.tpl-card__row { display: flex; align-items: center; gap: var(--sp-2); }
.tpl-card__name { font-size: var(--fs-h2); font-weight: var(--fw-bold); color: var(--c-ink); }
.tpl-card__desc { font-size: var(--fs-caption); color: var(--c-ink-2); }

.tpl-card__check {
  position: absolute; right: var(--sp-4); top: var(--sp-4);
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--c-brand); color: #fff; text-align: center; line-height: 44rpx; font-size: 26rpx;
}

.footer {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: var(--sp-3) var(--page-px);
  background: linear-gradient(180deg, rgba(245,246,248,0), var(--c-page) 40%);
}
