<!-- pages/resume/view.wxml -->
<view class="page-container">
  <view class="head">
    <text class="head__title">简历预览</text>
    <text class="head__sub">确认无误后即可导出 PDF / Word</text>
  </view>

  <!-- 简历概览卡 -->
  <view class="card resume-card">
    <view class="resume-card__top">
      <view class="resume-card__ava">{{avatar}}</view>
      <view class="resume-card__id">
        <text class="resume-card__name">{{name}}</text>
        <text wx:if="{{title}}" class="resume-card__title">{{title}}</text>
      </view>
    </view>
    <view class="resume-card__line" wx:if="{{phone}}">📱 {{phone}}</view>
    <view class="resume-card__line" wx:if="{{email}}">✉️ {{email}}</view>
    <view class="resume-card__line" wx:if="{{workCount}}">💼 工作经历 {{workCount}} 段</view>
    <view class="resume-card__line" wx:if="{{summary}}">📝 {{summary}}…</view>
  </view>

  <!-- 导出设置 -->
  <view class="section">
    <text class="section-title">导出设置</text>

    <view class="card set-card">
      <view class="set-row">
        <text class="set-row__label">语言版本</text>
        <view class="seg">
          <view class="seg-btn {{locale==='zh'?'on':''}}" data-id="zh" bindtap="onLocale">中文</view>
          <view class="seg-btn {{locale==='en'?'on':''}}" data-id="en" bindtap="onLocale">英文</view>
        </view>
      </view>
      <view class="set-row set-row--last" bindtap="togglePhoto">
        <text class="set-row__label">嵌入证件照</text>
        <view class="toggle {{includePhoto?'on':''}}"></view>
      </view>
    </view>
  </view>

  <!-- 导出按钮 -->
  <view class="footer safe-bottom">
    <button class="btn btn-ghost btn-block" loading="{{exporting}}" disabled="{{exporting}}" bindtap="exportWord">导出 Word</button>
    <button class="btn btn-primary btn-block" loading="{{exporting}}" disabled="{{exporting}}" bindtap="exportPdf">导出 PDF</button>
  </view>
</view>
