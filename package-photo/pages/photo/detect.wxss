@import "../../../styles/tokens.wxss";

.report { padding: var(--sp-4); }
.report__score { display: flex; align-items: center; gap: var(--sp-4); }
.report__score .ring { width: 140rpx; height: 140rpx; font-size: var(--fs-data); font-weight: var(--fw-bold); }
.report__score-text { display: flex; flex-direction: column; }
.report__items { margin-top: var(--sp-4); display: flex; flex-direction: column; gap: var(--sp-3); }

.item { display: flex; align-items: center; gap: var(--sp-3); }
.item__label { width: 160rpx; font-size: var(--fs-caption); color: var(--c-ink-2); }
.item__bar { flex: 1; height: 16rpx; border-radius: var(--r-pill); background: var(--c-surface-2); overflow: hidden; }
.item__fill { height: 100%; background: var(--grad-brand); border-radius: var(--r-pill); transition: width var(--dur-count) var(--ease-out); }
.item__score { width: 72rpx; text-align: right; font-size: var(--fs-caption); font-weight: var(--fw-semi); color: var(--c-success); }
.item__score.fail { color: var(--c-danger); }

.reedit-btn { margin-top: var(--sp-6); }
