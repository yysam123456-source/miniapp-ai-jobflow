<view class="edit">

  <!-- 预览舞台 -->
  <view class="stage stage--{{layout}}">
    <image wx:if="{{preview}}" class="stage__img" src="{{preview}}" mode="aspectFit" />
    <canvas wx:if="{{masking}}" type="2d" id="maskCanvas" class="mask-canvas"
      bindtouchstart="onMaskTouch" bindtouchmove="onMaskTouch"></canvas>
    <view wx:if="{{processing}}" class="stage__chip">处理中…</view>
  </view>

  <!-- 工具 Tab 横滑 -->
  <scroll-view scroll-x class="tool-tabs">
    <view wx:for="{{tabs}}" wx:key="key"
      class="tool-tab {{activeTab === item.key ? 'on' : ''}}"
      data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</view>
  </scroll-view>

  <!-- 面板 -->
  <view class="panel">
    <!-- 换底 -->
    <view wx:if="{{activeTab === 'bg'}}" class="panel__row">
      <view wx:for="{{bgColors}}" wx:key="key"
        class="chip {{bg === item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="chooseBg">{{item.label}}</view>
    </view>

    <!-- 裁剪（端内 canvas） -->
    <view wx:elif="{{activeTab === 'crop'}}" class="panel__col">
      <view class="panel__row">
        <view wx:for="{{sizes}}" wx:key="id"
          class="chip {{cropSize === item.id ? 'on' : ''}}" data-id="{{item.id}}" bindtap="chooseCropSize">{{item.label}} · {{item.spec}}</view>
      </view>
      <button class="btn btn-primary btn-sm" bindtap="onCrop">按规格裁剪</button>
    </view>

    <!-- 美颜 -->
    <view wx:elif="{{activeTab === 'beauty'}}" class="panel__sliders">
      <view class="slider-row">
        <text class="slider-row__label">磨皮</text>
        <slider min="0" max="100" value="{{beauty.smooth}}" activeColor="#16A36E"
          data-field="smooth" bindchanging="onBeautyChange" bindchange="onBeautyChange" />
      </view>
      <view class="slider-row">
        <text class="slider-row__label">美白</text>
        <slider min="0" max="100" value="{{beauty.whiten}}" activeColor="#16A36E"
          data-field="whiten" bindchanging="onBeautyChange" bindchange="onBeautyChange" />
      </view>
      <button class="btn btn-primary btn-sm" bindtap="applyBeauty">应用美颜</button>
    </view>

    <!-- 修图（调整：亮度/对比度/饱和度/色温/锐度） -->
    <view wx:elif="{{activeTab === 'adjust'}}" class="panel__sliders">
      <view class="slider-row">
        <text class="slider-row__label">亮度</text>
        <slider min="-100" max="100" value="{{adjust.brightness}}" activeColor="#16A36E"
          data-field="brightness" bindchanging="onAdjustChange" bindchange="onAdjustChange" />
      </view>
      <view class="slider-row">
        <text class="slider-row__label">对比度</text>
        <slider min="-100" max="100" value="{{adjust.contrast}}" activeColor="#16A36E"
          data-field="contrast" bindchanging="onAdjustChange" bindchange="onAdjustChange" />
      </view>
      <view class="slider-row">
        <text class="slider-row__label">饱和度</text>
        <slider min="-100" max="100" value="{{adjust.saturation}}" activeColor="#16A36E"
          data-field="saturation" bindchanging="onAdjustChange" bindchange="onAdjustChange" />
      </view>
      <view class="slider-row">
        <text class="slider-row__label">色温</text>
        <slider min="-100" max="100" value="{{adjust.temperature}}" activeColor="#16A36E"
          data-field="temperature" bindchanging="onAdjustChange" bindchange="onAdjustChange" />
      </view>
      <view class="slider-row">
        <text class="slider-row__label">锐度</text>
        <slider min="0" max="100" value="{{adjust.sharpen}}" activeColor="#16A36E"
          data-field="sharpen" bindchanging="onAdjustChange" bindchange="onAdjustChange" />
      </view>
      <button class="btn btn-primary btn-sm" bindtap="applyAdjust">应用修图</button>
    </view>

    <!-- 去水印（涂 mask → 云函数 inpaint） -->
    <view wx:elif="{{activeTab === 'inpaint'}}" class="panel__col">
      <text class="panel__hint">用手指在照片上涂抹需要消除的水印 / 瑕疵区域，再点「消除水印」。</text>
      <view class="panel__row">
        <button class="btn btn-ghost btn-sm" bindtap="clearMask">清除涂抹</button>
        <button class="btn btn-primary btn-sm" bindtap="onInpaint">消除水印</button>
      </view>
    </view>

    <!-- 排版 -->
    <view wx:elif="{{activeTab === 'layout'}}" class="panel__row">
      <view wx:for="{{layouts}}" wx:key="key"
        class="chip {{layout === item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="chooseLayout">{{item.label}}</view>
    </view>

    <!-- 抠图 -->
    <view wx:else class="panel__hint">
      <text>已自动智能抠图，可到「换底」选择底色，或用「裁剪 / 去水印」在本地完成调整</text>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="actions safe-bottom">
    <button class="btn btn-ghost" bindtap="goDetect">合规检测</button>
    <button class="btn btn-primary btn-block" bindtap="goExport">保存 / 导出</button>
  </view>

  <!-- 离屏画布（裁剪/水印） -->
  <canvas type="2d" id="workCanvas" class="work-canvas"></canvas>
</view>
